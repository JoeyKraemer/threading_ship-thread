@rendermode InteractiveServer
@using ShipAndThread.Domain.Entities
@using ShipAndThread.Domain.Enums
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.SignalR.Client
@using ShipAndThread.Application.Services
@inject TruckService TruckService
@using ShipAndThread.Components.Pages
@inject IJSRuntime JS

@code {
    [Parameter] public int TruckId { get; set; }
    [Parameter] public string LicensePlate { get; set; } = "Unknown Plate";
    [Parameter] public int? Capacity { get; set; } = 0;
    [Parameter] public LocationHistory? LocationHistory { get; set; }
    [Parameter] public List<Cargo> CargoList { get; set; } = new();
    
    private HubConnection? _hubConnection;
    private Truck? _truck;
    private string MapId = $"map-{Guid.NewGuid()}";

    private bool _isExpanded = false;

    private void ToggleExpand()
    {
        _isExpanded = !_isExpanded;
        StateHasChanged();
    }
    
    private List<LeafletMap.TruckMarker> GetSingleMarker()
    {
        if (LocationHistory == null)
        {
            return [];
        }

        return
        [
            new LeafletMap.TruckMarker
            {
                TruckId = TruckId.ToString(),
                Latitude = LocationHistory.Latitude,
                Longitude = LocationHistory.Longitude,
                Color = "yellow"
            }
        ];
    }
    
    protected override async Task OnInitializedAsync()
    {
        _truck = await TruckService.GetTruckByIdAsync(TruckId);
        
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/communicationHub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<Home.TruckLocationUpdate>("ReceiveLocationUpdate", async update =>
        {
            if (update.TruckId == TruckId)
            {
                LocationHistory = new LocationHistory
                {
                    TruckId = update.TruckId,
                    Truck = _truck,
                    Latitude = update.Latitude,
                    Longitude = update.Longitude,
                    Timestamp = update.Timestamp
                };
                
                await JS.InvokeVoidAsync("centerMap", MapId, update.Latitude, update.Longitude);

                await InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.On<List<Cargo>>("ReceiveCargoUpdate", cargoList =>
        {
            var activeCargo = cargoList
                .Where(c => c.TruckId == TruckId && c.Status != CargoStatus.Delivered)
                .ToList();

            CargoList = activeCargo;
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
    }
}

<div class="truck-card">
    <div class="truck-closed">
        <div class="truck-info">
            <img src="images/truckImage.png" alt="Truck Image" class="truck-image" />
            <div class="truck-title">
                <h2>@TruckId / @LicensePlate</h2>
            </div>
        </div>
        <button @onclick="ToggleExpand" class="expand-btn">
            @(_isExpanded ? "▲" : "▼")
        </button>
    </div>

    @if (_isExpanded)
    {
        <div class="truck-open">
            <div class="truck-details expanded">
                <div class="map-card">
                    @if (LocationHistory != null)
                    {
                        <LeafletMap MapId="@MapId"
                                    Latitude="@LocationHistory.Latitude"
                                    Longitude="@LocationHistory.Longitude"
                                    Zoom="12"
                                    Trucks="@GetSingleMarker()" />
                    }
                    else
                    {
                        <LeafletMap MapId="@MapId"
                                    Latitude="52.3800"
                                    Longitude="4.9000"
                                    Zoom="12" />
                    }
                </div>

                <div class="route-info">
                    <h4>ACTIVE CARGO</h4>
                    @if (CargoList.Any(c => c.Status != CargoStatus.Delivered))
                    {
                        <ul>
                            @foreach (var cargo in CargoList.Where(c => c.Status != CargoStatus.Delivered))
                            {
                                <li>
                                    <strong>Cargo ID:</strong> @cargo.Id <br />
                                    <strong>Status:</strong> @cargo.Status
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p>No active cargo.</p>
                    }
                </div>

            </div>
        </div>
    }
</div>
