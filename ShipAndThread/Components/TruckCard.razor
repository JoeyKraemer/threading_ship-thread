@rendermode InteractiveServer
@using ShipAndThread.Domain.Entities
@using ShipAndThread.Domain.Enums
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.SignalR.Client
@using ShipAndThread.Application.Services
@inject TruckService TruckService
@using ShipAndThread.Components.Pages
@inject IJSRuntime JS
@using System.Text.Json

<style>
    .delivered-cargo {
        color: #666;
        text-decoration: line-through;
        background-color: #f0f0f0;
        opacity: 0.8;
    }
    
    .active-cargo {
        color: #000;
        font-weight: bold;
        background-color: #e6f7ff;
    }
    
    .cargo-list li {
        margin-bottom: 8px;
        padding: 6px;
        border-radius: 4px;
        transition: all 0.3s ease;
    }
</style>

@code {
    [Parameter] public int TruckId { get; set; }
    [Parameter] public string LicensePlate { get; set; } = "Unknown Plate";
    [Parameter] public int? Capacity { get; set; } = 0;
    [Parameter] public LocationHistory? LocationHistory { get; set; }
    [Parameter] public List<Cargo> CargoList { get; set; } = new();
    
    private HubConnection? _hubConnection;
    private Truck? _truck;
    private string MapId = $"map-{Guid.NewGuid()}";

    private bool _isExpanded = false;

    private void ToggleExpand()
    {
        _isExpanded = !_isExpanded;
        StateHasChanged();
    }
    
    private List<LeafletMap.TruckMarker> GetSingleMarker()
    {
        if (LocationHistory == null)
        {
            return new List<LeafletMap.TruckMarker>();
        }

        return new List<LeafletMap.TruckMarker>
        {
            new LeafletMap.TruckMarker
            {
                TruckId = TruckId.ToString(),
                Latitude = LocationHistory.Latitude,
                Longitude = LocationHistory.Longitude,
                Color = "yellow"
            }
        };
    }
    
    protected override async Task OnInitializedAsync()
    {
        _truck = await TruckService.GetTruckByIdAsync(TruckId);
        
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/communicationHub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<Home.TruckLocationUpdate>("ReceiveLocationUpdate", async update =>
        {
            if (update.TruckId == TruckId)
            {
                LocationHistory = new LocationHistory
                {
                    TruckId = update.TruckId,
                    Truck = _truck,
                    Latitude = update.Latitude,
                    Longitude = update.Longitude,
                    Timestamp = update.Timestamp
                };
                
                await JS.InvokeVoidAsync("centerMap", MapId, update.Latitude, update.Longitude);

                await InvokeAsync(StateHasChanged);
            }
        });

        _hubConnection.On<List<object>>("ReceiveCargoUpdate", cargoObjects =>
        {
            var cargoList = new List<Cargo>();
            
            foreach (var obj in cargoObjects)
            {
                // Convert the dynamic object to JSON and then to a Cargo object
                var jsonElement = (JsonElement)obj;
                
                int cargoTruckId = jsonElement.GetProperty("TruckId").GetInt32();
                
                // Only process cargo for this truck
                if (cargoTruckId == TruckId)
                {
                    var cargoStatus = (CargoStatus)jsonElement.GetProperty("Status").GetInt32();
                    
                    var cargo = new Cargo
                    {
                        Id = jsonElement.GetProperty("Id").GetInt32(),
                        TruckId = cargoTruckId,
                        Status = cargoStatus
                    };
                    
                    // Check if Truck property exists and is not null
                    if (jsonElement.TryGetProperty("Truck", out JsonElement truckElement) && 
                        truckElement.ValueKind != JsonValueKind.Null)
                    {
                        cargo.Truck = new Truck
                        {
                            TruckId = truckElement.GetProperty("TruckId").GetInt32(),
                            LicensePlate = truckElement.TryGetProperty("LicensePlate", out var lpElement) && 
                                          lpElement.ValueKind != JsonValueKind.Null ? 
                                          lpElement.GetString() : null,
                            Capacity = truckElement.TryGetProperty("Capacity", out var capElement) && 
                                      capElement.ValueKind != JsonValueKind.Null ? 
                                      capElement.GetInt32() : null
                        };
                    }
                    
                    cargoList.Add(cargo);
                }
            }
            
            // Update the main cargo list
            CargoList = cargoList;
            
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
    }
}

<div class="truck-card">
    <div class="truck-closed">
        <div class="truck-info">
            <img src="images/truckImage.png" alt="Truck Image" class="truck-image" />
            <div class="truck-title">
                <h2>@TruckId / @LicensePlate</h2>
            </div>
        </div>
        <button @onclick="ToggleExpand" class="expand-btn">
            @(_isExpanded ? "▲" : "▼")
        </button>
    </div>

    @if (_isExpanded)
    {
        <div class="truck-open">
            <div class="truck-details expanded">
                <div class="map-card">
                    @if (LocationHistory != null)
                    {
                        <LeafletMap MapId="@MapId"
                                    Latitude="@LocationHistory.Latitude"
                                    Longitude="@LocationHistory.Longitude"
                                    Zoom="12"
                                    Trucks="@GetSingleMarker()" />
                    }
                    else
                    {
                        <LeafletMap MapId="@MapId"
                                    Latitude="52.3800"
                                    Longitude="4.9000"
                                    Zoom="12" />
                    }
                </div>

                <div class="route-info">
                    <h4>CARGO LIST</h4>
                    @if (CargoList.Any())
                    {
                        <ul class="cargo-list">
                            @foreach (var cargo in CargoList.OrderBy(c => c.Id))
                            {
                                <li class="@(cargo.Status == CargoStatus.Delivered ? "delivered-cargo" : "active-cargo")">
                                    <strong>Cargo ID:</strong> @cargo.Id <br />
                                    <strong>Status:</strong> @cargo.Status
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p>No cargo assigned to this truck.</p>
                    }
                </div>

            </div>
        </div>
    }
</div>
