@page "/cargoManagement"
@using ShipAndThread.Domain.Entities
@using ShipAndThread.Application.Services
@inject CargoService CargoService
@using Microsoft.AspNetCore.SignalR.Client
@using ShipAndThread.Domain.Enums
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Cargo Management</PageTitle>

<div class="search">
    <LiveSearch OnSearchChanged="HandleSearchChanged" />
</div>

@if (filteredCargo.Any())
{
    @foreach (var cargo in filteredCargo)
    {
        <CargoCard Cargo="@cargo" />
    }
}
else
{
    <p>No cargo found matching the search criteria.</p>
}

@code {
    private HubConnection? _hubConnection;
    private string searchText = "";

    private List<Cargo> allCargo = new();
    private List<Cargo> filteredCargo = new();

    protected override async Task OnInitializedAsync()
    {
        allCargo = await CargoService.GetAllCargoAsync();
        filteredCargo = allCargo;

        // Setup SignalR connection
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/communicationHub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<List<Cargo>>("ReceiveCargoUpdate", (updatedCargo) =>
        {
            allCargo = updatedCargo
                .Where(c => c.Status != CargoStatus.Delivered)
                .ToList();
            FilterResults(); // Reapply search
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
    }

    private void HandleSearchChanged(string searchText)
    {
        this.searchText = searchText;
        FilterResults();
    }

    private void FilterResults()
    {
        if (!string.IsNullOrWhiteSpace(searchText))
        {
            filteredCargo = allCargo
                .Where(cargo => cargo.Id.ToString().Contains(searchText, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
        else
        {
            filteredCargo = allCargo;
        }
    }
}