@page "/cargoManagement"
@using ShipAndThread.Domain.Entities
@rendermode InteractiveServer

<PageTitle>Cargo Management</PageTitle>

<div class="search">
    <LiveSearch OnSearchChanged="HandleSearchChanged" />
</div>

@if (filteredCargo.Any())
{
    @foreach (var cargo in filteredCargo)
    {
        <CargoCard CargoId="@cargo.Id"
                   Status="@cargo.Status"
                   TruckLicense="@cargo.Truck?.LicensePlate" />
    }
}
else
{
    <p>No cargo found matching the search criteria.</p>
}

@code {
    private string searchText = "";
    
    // Sample cargo data
    private List<Cargo> allCargo = new();

    private List<Cargo> filteredCargo;

    // Initialize and populate the filteredCargo list
    protected override void OnInitialized()
    {
        filteredCargo = allCargo; // Initially, show all cargo items
        Console.WriteLine("OnInitialized: All cargo loaded."); // Debugging line
    }

    // Handle search change event and filter the results
    private void HandleSearchChanged(string searchText)
    {
        Console.WriteLine($"HandleSearchChanged called with searchText: {searchText}"); // Debugging line
        this.searchText = searchText;
        FilterResults();
    }

    // Filter cargo list based on the search text
    private void FilterResults()
    {
        Console.WriteLine($"FilterResults called with searchText: {searchText}"); // Debugging line

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            // Debugging: Print allCargo to check its content
            Console.WriteLine("Filtering cargo items...");
            foreach (var cargo in allCargo)
            {
                Console.WriteLine($"CargoId: {cargo.Id}, Status: {cargo.Status}, TruckLicense: {cargo.Truck.LicensePlate}");
            }

            // Filter cargo by CargoId matching the search text
            filteredCargo = allCargo
                .Where(cargo => cargo.Id.ToString().Contains(searchText, StringComparison.OrdinalIgnoreCase))
                .ToList();
            Console.WriteLine($"Filtered cargo count: {filteredCargo.Count}"); // Debugging line
        }
        else
        {
            // If no search text, show all cargo items
            Console.WriteLine("No search text, showing all cargo."); // Debugging line
            filteredCargo = allCargo;
        }
    }
}
