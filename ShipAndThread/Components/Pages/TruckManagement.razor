@page "/truckManagement"
@using ShipAndThread.Domain.Entities
@using ShipAndThread.Application.Services
@inject TruckService TruckService
@rendermode InteractiveServer

<PageTitle>Truck Management</PageTitle>

<div class="search">
    <LiveSearch OnSearchChanged="HandleSearchChanged" />
</div>

@if (filteredTrucks.Any())
{
    @foreach (var truck in filteredTrucks)
    {
        <TruckCard @key="@truck.TruckId"
                   TruckId="@truck.TruckId"
                   LicensePlate="@truck.LicensePlate"
                   Capacity="@truck.Capacity"
                   LocationHistory="@truck.LocationHistory"
                   CargoList="@truck.CargoList.ToList()"
                  />
    }
}
else
{
    <p>No trucks found matching the search criteria.</p>
}

@code {
    private string searchText = "";
    private List<Truck> allTrucks = new();
    private List<Truck> filteredTrucks = new();

    protected override async void OnInitialized()
    {
        await LoadTrucksAsync();
    }
    
    private async Task LoadTrucksAsync()
    {
        allTrucks = await TruckService.GetAllTrucksAsync();
        filteredTrucks = new List<Truck>(allTrucks);
    }

    private void HandleSearchChanged(string searchText)
    {
        this.searchText = searchText;
        FilterResults();
    }

    private void FilterResults()
    {
        if (!string.IsNullOrWhiteSpace(searchText))
        {
            filteredTrucks = allTrucks
                .Where(truck => truck.TruckId.ToString().Contains(searchText, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
        else
        {
            filteredTrucks = allTrucks;
        }
    }
}
