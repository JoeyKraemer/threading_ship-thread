@page "/"

@using Microsoft.AspNetCore.SignalR.Client
@using ShipAndThread.BlackBox
@inject NavigationManager Navigation
@inject ITruckDataSimulationService TruckDataSimulationService
@using ShipAndThread.Application.Services
@inject TruckService TruckService
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<div class="main-map">
    <LeafletMap Latitude="52.3800" Longitude="4.9000" Zoom="11" Trucks="@truckMarkers" />
</div>

<button @onclick="StartSimulation">Start Simulation</button>

<div class="log">
    <h2>Activity Log</h2>
    <ul>
        @foreach (var entry in activityLog)
        {
            <li>
                <p>@entry.Time.ToString("HH:mm:ss")</p>
                <p>
                    @((MarkupString)entry.Message)
                </p>
            </li>
        }
    </ul>
</div>

@code {
    private class ActivityEntry
    {
        public DateTime Time { get; set; }
        public string Message { get; set; } = "";
        public string Color { get; set; } = "";
    }

    private readonly List<ActivityEntry> activityLog = new();
    private readonly List<LeafletMap.TruckMarker> truckMarkers = new();

    private HubConnection? _hubConnection;
    private readonly List<TruckLocationUpdate> _truckUpdates = [];

    protected override async Task OnInitializedAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/communicationHub"))
            .AddJsonProtocol(options =>
            {
            options.PayloadSerializerOptions.PropertyNameCaseInsensitive = true;
            })
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<TruckLocationUpdate>("ReceiveLocationUpdate", update =>
        {
            UpdateTruckMarker(update);
            LogActivity(update);

            _truckUpdates.Add(update);
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        
        // Load existing trucks with location data
        var trucks = (await TruckService.GetAllTrucksAsync())
            .Where(t => t.LocationHistory != null)
            .ToList();

        foreach (var truck in trucks)
        {
            truckMarkers.Add(new LeafletMap.TruckMarker
            {
                TruckId = truck.TruckId.ToString(),
                Latitude = truck.LocationHistory!.Latitude,
                Longitude = truck.LocationHistory.Longitude,
                Color = GetColorFromTruckId(truck.TruckId.ToString())
            });
        }
    }

    private void UpdateTruckMarker(TruckLocationUpdate update)
    {
        var marker = truckMarkers.FirstOrDefault(t => t.TruckId == update.TruckId.ToString());

        if (marker == null)
        {
            marker = new LeafletMap.TruckMarker
            {
                TruckId = update.TruckId.ToString(),
                Color = GetColorFromTruckId(update.TruckId.ToString())
            };
            truckMarkers.Add(marker);
        }

        marker.Latitude = update.Latitude;
        marker.Longitude = update.Longitude;
    }

    private void LogActivity(TruckLocationUpdate update)
    {
        string color = GetColorFromTruckId(update.TruckId.ToString());

        activityLog.Add(new ActivityEntry
        {
            Time = update.Timestamp,
            Message = $"<span style=\"text-decoration: underline; text-decoration-color: {color};\">Truck {update.TruckId}</span> updated location to ({update.Latitude:F4}, {update.Longitude:F4})",
            Color = color
        });
    }

    private string GetColorFromTruckId(string truckId)
    {
        var colors = new[] { "red", "blue", "green", "orange", "purple", "pink", "yellow", "brown", "teal" };
        int hash = Math.Abs(truckId.GetHashCode());
        return colors[hash % colors.Length];
    }

    private async Task StartSimulation()
    {
        try
        {
            await TruckDataSimulationService.StartSimulationAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Simulation error: {ex.Message}");
        }
    }

    public class TruckLocationUpdate
    {
        public int TruckId { get; set; }
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public DateTime Timestamp { get; set; }
    }
}
